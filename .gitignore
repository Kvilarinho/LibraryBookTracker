# .gitignore for C# .NET projects
# Build results
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/

# OS generated files
.DS_Store
Thumbs.db

# NuGet
*.nupkg
# Package restore
project.lock.json
project.fragment.lock.json
artifacts/

# Rider
.idea/
*.sln.iml

# Logs
*.log

# Others
*.vspscc
*.vssscc
